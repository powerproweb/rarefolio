# Main-site private download claim flow environment
#
# These variables are read by api/download/_common.php using getenv(),
# with this file as local fallback for shared-hosting setups.
#
# Keep real values in server env or api/download/.env (gitignored).

# Marketplace private ownership verifier endpoint
RF_MARKET_OWNERSHIP_VERIFY_URL=https://market.rarefolio.io/api/private/ownership-verify.php

# Shared secret for Authorization: Bearer <secret>
# Must match DOWNLOAD_VERIFY_SHARED_SECRET in marketplace .env
RF_MARKET_OWNERSHIP_VERIFY_SECRET=change_me_generate_a_long_random_string

# Ticket signing secret for short-lived download tickets
RF_DOWNLOAD_TICKET_SECRET=change_me_generate_a_long_random_string

# Optional:
# true  -> all /download.php requests require a valid ticket
# false -> legacy direct cert downloads still work, ticketed requests validated
RF_DOWNLOAD_TICKET_REQUIRED=false
