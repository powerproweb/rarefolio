# Main-site webhook receiver environment
#
# These env vars are read by /api/webhook/_hmac.php using getenv().
# On shared hosting, set them via SetEnv in .htaccess, the hosting control
# panel, or a php-fpm pool config — NOT by committing a real .env file here.
#
# Generate a fresh secret with:  openssl rand -hex 32

# Required. MUST match PUBLIC_SITE_WEBHOOK_SECRET in the marketplace .env
RF_WEBHOOK_SECRET=change_me_generate_a_long_random_string

# Optional. Max allowed clock skew in seconds between sender and receiver.
# Defaults to 300.
# RF_WEBHOOK_MAX_SKEW=300

# Optional. Directory used to store one-shot nonces for replay protection.
# Defaults to the system temp dir. Must be writable by the web user.
# RF_WEBHOOK_NONCE_DIR=/var/lib/rarefolio/webhook-nonces
