# ============================================================
# SECRETS & CREDENTIALS  -- never commit these
# ============================================================
api/_config.php
.env
.env.*
!.env.example
api/webhook/.env
api/webhook/.env.*
!api/webhook/.env.example

# ============================================================
# WEBHOOK RUNTIME STATE  -- nonces, delivery logs, token cache (server-only)
# ============================================================
uploads/webhook-log/
uploads/webhook-cache/
rf_webhook_nonces/

# ============================================================
# BACKUP / BROKEN FILES
# ============================================================
*.bak
*.broke
*.orig
*.tmp

# ============================================================
# PDF STORAGE (outside webroot on server, not part of codebase)
# ============================================================
rf_storage/

# ============================================================
# OS FILES
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# IDE / EDITOR
# ============================================================
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# ============================================================
# LOGS
# ============================================================
*.log
error_log

# ============================================================
# VENDOR / DEPENDENCIES  -- install via Composer, not git
# ============================================================
dompdf/
vendor/
composer.lock

# ============================================================
# LARGE COLLECTION ASSETS  -- too big for git / GitHub
# ============================================================
assets/img/collection/
assets/downloads/

# ggshield scan cache
.cache_ggshield
