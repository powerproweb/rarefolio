# ============================================================
# SECRETS & CREDENTIALS  -- never commit these
# ============================================================
api/_config.php
.env
api/webhook/.env
api/webhook/.env.old
api/webhook/.env.production
api/admin/run_migrations.php

# ============================================================
# WEBHOOK RUNTIME STATE  -- nonces, delivery logs (server-only)
# ============================================================
uploads/webhook-log/
uploads/webhook-cache/
uploads/download-claims/
rf_webhook_nonces/

# ============================================================
# BACKUP / BROKEN FILES
# ============================================================
*.bak
*.broke
*.orig
*.tmp

# ============================================================
# PDF STORAGE (outside webroot on server, not part of codebase)
# ============================================================
rf_storage/

# ============================================================
# OS FILES
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# IDE / EDITOR
# ============================================================
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# ============================================================
# LOGS
# ============================================================
*.log
error_log
.cache_ggshield

# ============================================================
# VENDOR / DEPENDENCIES  -- install via Composer, not git
# ============================================================
dompdf/
vendor/
composer.lock

# ============================================================
# LARGE COLLECTION ASSETS  -- too big for git / GitHub
# ============================================================
# Founders (scnft_founders/) is intentionally tracked — 8 files, ~1.7 MB.
# The large zodiac/steampunk series remain gitignored.
assets/img/collection/scnft_zodiac_*/
assets/img/collection/scnft_sp_*/
assets/img/collection/scnft_new_series/
assets/downloads/
# Local source renders for Founders (runtime uses qd-silver-*.jpg files)
assets/img/collection/scnft_founders/*_4000x4000_rbg_32bit_300dpi_png*.png
assets/img/collection/scnft_founders/*_8000x_cmyk_16bit_300dpi.png
