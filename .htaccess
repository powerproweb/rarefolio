# <<<|||\\\---*** This is in the root https://rarefolio.io/ Rarefolio.io site ***---///|||>>>
# Last updated: 2026-03-11
# Backup of previous version: .htaccess.old1

# ===========================================================================
# 1. CUSTOM ERROR PAGES
# ===========================================================================
ErrorDocument 404 /404.html
ErrorDocument 403 /404.html

# ===========================================================================
# 2. REWRITES, HTTPS + NON-WWW CANONICALIZATION
#    All traffic → https://rarefolio.io (matches canonical URLs)
# ===========================================================================
<IfModule mod_env.c>
  SetEnv RF_MARKET_OWNERSHIP_VERIFY_URL https://market.rarefolio.io/api/private/ownership-verify.php
  SetEnv RF_MARKET_OWNERSHIP_VERIFY_SECRET ***REMOVED_SECRET***
  SetEnv RF_DOWNLOAD_TICKET_SECRET ***REMOVED_SECRET***
  SetEnv RF_DOWNLOAD_TICKET_REQUIRED true
</IfModule>
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Pass HTTP Basic Auth credentials through to PHP (required on BlueHost)
  RewriteCond %{HTTP:Authorization} ^(.*)
  RewriteRule .* - [e=HTTP_AUTHORIZATION:%1]

  # Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Force non-www (www → non-www)
  RewriteCond %{HTTP_HOST} ^www\.rarefolio\.io$ [NC]
  RewriteRule ^(.*)$ https://rarefolio.io/$1 [L,R=301]

  # Retired page hard-block: do not serve old Inventors prelaunch route
  RewriteRule ^collection-inventors-guild-prelaunch(\\.html)?/?$ - [G,L,NC]

  # --- Protect Silver Shard Calculator with HTTP Basic Auth (served via PHP gate) ---
  RewriteRule ^collection-silverbar-calculator/?$ collection-silverbar-calculator-protected.php [QSA,L]
  RewriteRule ^collection-silverbar-calculator\.html$ collection-silverbar-calculator-protected.php [QSA,L]

  # --- Collection block router (scalable sub-pages via single PHP template) ---
  # /collection/silverbar-01/aquarius?batch=13 -> _col/block.php?bar=01&block=aquarius&batch=13
  RewriteRule ^collection/silverbar-([0-9]{2})/([a-z0-9-]+)/?$ _col/block.php?bar=$1&block=$2 [QSA,L]

  # --- 301 redirects: old static sub-pages -> new clean URLs ---
  RewriteRule ^collection-silverbar-([0-9]{2})-([a-z0-9-]+)\.html$ /collection/silverbar-$1/$2 [R=301,L]
  RewriteRule ^collection-silverbar-([0-9]{2})-([a-z0-9-]+)$ /collection/silverbar-$1/$2 [R=301,L]

  # Strip .html from URLs
  RewriteCond %{THE_REQUEST} \s/+(.+)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]

  # Internally serve the .html file for the clean URL
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+)$ $1.html [L]
</IfModule>

# ===========================================================================
# 3. SECURITY HEADERS
# ===========================================================================
<IfModule mod_headers.c>
  # Prevent MIME-type sniffing
  Header set X-Content-Type-Options "nosniff"

  # Prevent clickjacking (site cannot be embedded in iframes on other domains)
  Header set X-Frame-Options "SAMEORIGIN"

  # Control referrer info sent to other sites
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  # Permissions Policy, disable features the site doesn't use
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"

  # HSTS, tell browsers to always use HTTPS (1 year)
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS

  # Prevent pages from being cached when served over HTTP (belt-and-suspenders)
  Header set X-XSS-Protection "1; mode=block"
</IfModule>

# ===========================================================================
# 4. BROWSER CACHING (Expires)
#    Static assets get long cache lifetimes; HTML stays fresh.
# ===========================================================================
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML, short cache so content updates are seen quickly
  ExpiresByType text/html                 "access plus 1 hour"

  # CSS & JS, 1 month (cache-bust by renaming or query string on deploy)
  ExpiresByType text/css                  "access plus 1 month"
  ExpiresByType application/javascript    "access plus 1 month"
  ExpiresByType text/javascript           "access plus 1 month"

  # Images, 1 year (these rarely change)
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/gif                 "access plus 1 year"
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"
  ExpiresByType image/vnd.microsoft.icon  "access plus 1 year"

  # Fonts, 1 year
  ExpiresByType font/woff                 "access plus 1 year"
  ExpiresByType font/woff2                "access plus 1 year"
  ExpiresByType application/font-woff     "access plus 1 year"
  ExpiresByType application/font-woff2    "access plus 1 year"

  # PDFs, 1 month
  ExpiresByType application/pdf           "access plus 1 month"

  # Manifest & JSON
  ExpiresByType application/manifest+json "access plus 1 week"
  ExpiresByType application/json          "access plus 1 hour"

  # XML (sitemap, RSS)
  ExpiresByType application/xml           "access plus 1 hour"
  ExpiresByType text/xml                  "access plus 1 hour"
</IfModule>

# ===========================================================================
# 5. GZIP / DEFLATE COMPRESSION
#    Reduces transfer size for text-based assets (~60-70% smaller).
# ===========================================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/manifest+json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE font/woff
  AddOutputFilterByType DEFLATE font/woff2
</IfModule>

# ===========================================================================
# 6. CORRECT MIME TYPES
#    Ensures browsers interpret files correctly.
# ===========================================================================
<IfModule mod_mime.c>
  AddType image/webp                .webp
  AddType image/svg+xml             .svg .svgz
  AddType application/manifest+json .webmanifest
  AddType application/json          .json
  AddType application/pdf           .pdf
  AddType font/woff                 .woff
  AddType font/woff2                .woff2
  AddType text/javascript           .mjs
</IfModule>

# ===========================================================================
# 7. ETAG CONFIGURATION
#    Use file modification time only (more reliable across load-balanced servers).
# ===========================================================================
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>
FileETag MTime Size

# ===========================================================================
# 8. BLOCK ACCESS TO SENSITIVE FILES
#    Prevent direct access to dotfiles, backups, and config.
# ===========================================================================

# Block all dotfiles except .well-known (used by SSL cert renewals)
<IfModule mod_rewrite.c>
  RewriteRule ^(\.(?!well-known)) - [F,L]
</IfModule>

# Block backup and config files
<FilesMatch "\.(bak|old1|config|dist|inc|ini|log|sh|sql|swp)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>

# Block access to hidden version control directories
<IfModule mod_rewrite.c>
  RewriteRule ^(\.|git|svn|hg) - [F,L]
</IfModule>

# ===========================================================================
# 9. PREVENT DIRECTORY LISTING
# ===========================================================================
Options -Indexes

# ===========================================================================
# 10. IMAGE HOTLINK PROTECTION (optional, uncomment to enable)
#     Blocks other sites from embedding your images and using your bandwidth.
# ===========================================================================
# <IfModule mod_rewrite.c>
#   RewriteCond %{HTTP_REFERER} !^$
#   RewriteCond %{HTTP_REFERER} !^https?://(www\.)?rarefolio\.io/ [NC]
#   RewriteCond %{HTTP_REFERER} !^https?://(www\.)?google\. [NC]
#   RewriteCond %{HTTP_REFERER} !^https?://(www\.)?bing\. [NC]
#   RewriteRule \.(jpg|jpeg|png|gif|webp|svg)$ - [F,NC]
# </IfModule>

# ===========================================================================
# 11. PHP HANDLER (cPanel)
# ===========================================================================
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php81 .php .php8 .phtml
</IfModule>

# <<<|||\\\---*** End - This is from the Rarefolio.io site ***---///|||>>>
