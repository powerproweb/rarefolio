# Auto-detect text files and normalise line endings
* text=auto

# Force LF for web files
*.html text eol=lf
*.php  text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.xml  text eol=lf
*.svg  text eol=lf

# Binaries
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.woff binary
*.woff2 binary
*.zip  binary
